{
  "name": "ghaith",
  "type": "module",
  "version": "1.0.0",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "predev": "pnpm run generate:signature && tsx scripts/generate-git-timestamps.ts",
    "dev": "astro dev",
    "prebuild": "pnpm run generate:signature && tsx scripts/generate-git-timestamps.ts",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "verify": "pnpm check && pnpm format:check && pnpm build && pnpm run audit:content && pnpm run audit:assets",
    "astro": "astro",
    "algolia:sync": "tsx scripts/sync-algolia-index.ts",
    "generate:signature": "tsx scripts/generate-signature-asset.ts",
    "audit:assets": "tsx scripts/audit-assets.ts",
    "audit:content": "tsx scripts/audit-content.ts",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "config:extract": "tsx scripts/config-extract.mjs",
    "config:apply": "node scripts/config-apply.mjs"
  },
  "devDependencies": {
    "prettier": "3.8.4",
    "prettier-plugin-astro": "0.14.1",
    "tar": "^7.5.16",
    "tsx": "^4.22.4"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/markdown-remark": "^7.2.0",
    "@astrojs/mdx": "^6.0.3",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@rowanmanning/feed-parser": "^2.1.3",
    "@waline/client": "^3.15.2",
    "astro": "^6.4.8",
    "katex": "^0.16.10",
    "lucide-static": "^0.562.0",
    "rehype-katex": "^7.0.0",
    "remark-directive": "^4.0.0",
    "remark-math": "^6.0.0",
    "remark-mdx": "^3.1.1",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5"
  }
}
